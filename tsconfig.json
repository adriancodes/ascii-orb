{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": false,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "ascii-orb": ["./src/index.ts"],
      "ascii-orb/core": ["./src/core.ts"]
    }
  },
  "include": ["src", "demo/src"]
}
